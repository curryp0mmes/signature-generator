{
  "name": "email-signature-generator",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-intl": "^6.1.1",
    "web-vitals": "^3.0.2",
    "zustand": "^4.1.1"
  },
  "scripts": {
    "start": "vite",
    "build": "npm run i18n:compile && tsc && vite build",
    "preview": "vite preview",
    "prettier": "prettier --write .",
    "i18n:extract": "formatjs extract \"src/**/*.{ts,tsx}\" --ignore \"src/**/*.d.ts\" --out-file lang/en.json",
    "i18n:compile": "formatjs compile-folder --ast lang src/locales"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@formatjs/cli": "^5.1.0",
    "@types/node": "^18.7.18",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.3",
    "prettier": "^2.7.1",
    "typescript": "^4.8.3",
    "vite": "^5.4.11"
  }
}
